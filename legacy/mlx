# Send an image to the tags server and stream booru-style positive/negative
# tags to stdout. Image is sent as a base64 data URL inside an OpenAI-style
# multimodal content array, which mlx_vlm.server accepts.
_send_image_tag_request() {
    local name="$1" port="$2" fallback="$3" image="$4"
    local pidfile="${LOG_DIR}/${name}.pid" model=""
    if [[ -f "${pidfile}" ]]; then
        local pid
        pid="$(<"${pidfile}")"
        if kill -0 "${pid}" 2>/dev/null; then
            local cmd
            cmd="$(ps -p "${pid}" -o command= 2>/dev/null)"
            model="${cmd##*--model }"
            model="${model%% *}"
        fi
    fi
    [[ -z "${model}" ]] && model="${fallback}"
    if [[ -z "${model}" ]]; then
        print -u2 "ERROR: ${name} server not running and no fallback model"
        return 1
    fi
    python3 -u - "http://${HOST}:${port}/v1/chat/completions" "${model}" "${image}" <<'PY'
import base64, json, mimetypes, sys, urllib.request

url, model, image_path = sys.argv[1], sys.argv[2], sys.argv[3]
mime, _ = mimetypes.guess_type(image_path)
if not mime or not mime.startswith("image/"):
    mime = "image/jpeg"
with open(image_path, "rb") as f:
    b64 = base64.b64encode(f.read()).decode("ascii")
data_url = f"data:{mime};base64,{b64}"

prompt = (
    "Generate exhaustive booru-style tags for this image, suitable as "
    "Stable Diffusion conditioning. Be granular and specific: each "
    "distinct visual element gets its own tag. Aim for 60 to 120 positive "
    "tags. Use lowercase, underscores instead of spaces where idiomatic "
    "(e.g. red_hair, looking_at_viewer).\n\n"
    "Cover every applicable category:\n"
    "  - subject count and type (e.g. 1girl, 1boy, solo, multiple_people)\n"
    "  - body and build: body_type (slim, athletic, curvy, petite, muscular, plump), height impression, age range, body proportions, body posture\n"
    "  - chest and torso: bust size (small_breasts, medium_breasts, large_breasts, flat_chest), cleavage, sideboob, underboob, navel, midriff, abs, ribs, shoulders, collarbone, back\n"
    "  - waist, hips, butt, thigh and leg detail: wide_hips, narrow_waist, thick_thighs, thigh_gap, long_legs, calves, ankles, bare_legs, crossed_legs\n"
    "  - arms and hands: arm position, bare_arms, forearms, wrist, hand_pose, finger position, fingernails, nail_polish, rings, bracelets\n"
    "  - feet: barefoot, toes, toenails, foot_pose\n"
    "  - skin: skin_tone (pale, fair, tan, dark, olive), skin_texture, freckles, moles, beauty_mark, tan_lines, scars, tattoos, piercings, blush, sweat\n"
    "  - face and head: face_shape (round, oval, heart-shaped), jawline, cheekbones, nose, ears, dimples, double_chin if present\n"
    "  - hair: color (including streaks, highlights, ombre, two-tone), length (short, shoulder-length, waist-length), texture (straight, wavy, curly), styling (ponytail, twintails, braid, bun, bangs, side-swept, hair_over_one_eye), hair_ornament\n"
    "  - eyes: color, shape (almond, round, narrow), eyelashes, eyeshadow, eyeliner, mascara, eye_contact / gaze direction\n"
    "  - mouth and lips: lip color, lip_gloss, lipstick, teeth, tongue, parted_lips, open_mouth, smile, smirk, grin, neutral_expression\n"
    "  - expression and emotion: confident, shy, seductive, neutral, happy, etc.\n"
    "  - clothing: each garment, color, fabric (sheer, denim, leather, silk), fit (tight, loose, oversized), state (unbuttoned, off-shoulder, rolled-up), accessories, jewelry, headwear, footwear\n"
    "  - pose and action: full pose tag plus component tags (standing, sitting, leaning, arms_crossed, hands_on_hips, hand_on_chin)\n"
    "  - framing: shot type (close-up, cowboy_shot, full_body, portrait, upper_body), angle (from_above, from_below, dutch_angle, side_view, three-quarter_view), depth_of_field\n"
    "  - environment: indoor/outdoor, location, props, background objects, time_of_day, weather\n"
    "  - lighting: source, direction, mood (rim_lighting, soft_lighting, harsh_shadows, golden_hour, backlit)\n"
    "  - color palette and dominant hues\n"
    "  - art style: photorealistic, anime, oil_painting, watercolor, 3d_render, line_art, etc.\n"
    "  - quality modifiers: masterpiece, highly_detailed, sharp_focus, 8k, etc. (only if warranted)\n\n"
    "For body detail, do not skip tags just because they feel obvious or "
    "redundant; SD conditioning improves with more specific tags. If a "
    "category is genuinely not applicable (e.g. feet not visible), omit "
    "it silently, do not say 'not_visible'.\n\n"
    "For negative tags, list common artifacts and undesired qualities to "
    "block in a regeneration: blurry, low_quality, jpeg_artifacts, "
    "watermark, signature, text, deformed, extra_limbs, missing_fingers, "
    "bad_anatomy, bad_hands, bad_feet, bad_proportions, etc., plus "
    "anything specifically wrong in this image you would NOT want "
    "repeated. Aim for 20 to 40 negative tags.\n\n"
    "Respond with exactly two lines and nothing else:\n"
    "Positive: <comma-separated tags>\n"
    "Negative: <comma-separated tags>\n"
    "No prose, no preamble, no markdown, no numbering, no duplicates."
)

body = json.dumps({
    "model": model,
    "max_tokens": 2000,
    "temperature": 0.3,
    "repetition_penalty": 1.05,
    "stream": True,
    "messages": [{
        "role": "user",
        "content": [
            {"type": "text", "text": prompt},
            {"type": "image_url", "image_url": {"url": data_url}},
        ],
    }],
}).encode()
req = urllib.request.Request(url, data=body,
                             headers={"Content-Type": "application/json"})
try:
    with urllib.request.urlopen(req, timeout=600) as r:
        for raw in r:
            line = raw.decode("utf-8", "replace").rstrip("\r\n")
            if not line.startswith("data: "):
                continue
            payload = line[6:]
            if payload == "[DONE]":
                break
            try:
                chunk = json.loads(payload)
            except json.JSONDecodeError:
                continue
            tok = (chunk.get("choices") or [{}])[0].get("delta", {}).get("content")
            if tok:
                sys.stdout.write(tok)
                sys.stdout.flush()
    print()
except urllib.error.HTTPError as e:
    sys.stderr.write(f"ERROR: HTTP {e.code} {e.reason}: {e.read().decode('utf-8','replace')[:300]}\n")
    sys.exit(1)
except Exception as e:
    sys.stderr.write(f"ERROR: {e!r}\n")
    sys.exit(1)
PY
}

# ============================================================================
# Router (proxy that swaps chat model on demand based on request `model` field)
# ============================================================================
_router_profile_csv() {
    # Build comma-separated list of registered chat profiles for the router.
    local k out=""
    for k in "${(@k)CHAT_MODEL_PROFILES}"; do
        [[ -n "${out}" ]] && out="${out},${k}"
        [[ -z "${out}" ]] && out="${k}"
    done
    print -- "${out}"
}

_router_statics_csv() {
    # User-supplied ROUTER_STATICS wins.
    [[ -n "${ROUTER_STATICS}" ]] && { print -- "${ROUTER_STATICS}"; return; }
    local out=""
    local tags_alias="${ROUTER_TAGS_ALIAS:-${TAGS_MODEL:t}}"
    if [[ -n "${TAGS_PORT}" && -n "${tags_alias}" ]]; then
        out="${tags_alias}=http://${MLX_HOST}:${TAGS_PORT}"
    fi
    if [[ -n "${EMBED_PORT}" && -n "${ROUTER_EMBED_ALIAS}" ]]; then
        [[ -n "${out}" ]] && out="${out},"
        out="${out}${ROUTER_EMBED_ALIAS}=http://${MLX_HOST}:${EMBED_PORT}"
    fi
    local tts_alias="${ROUTER_TTS_ALIAS:-${TTS_MODEL:t}}"
    if [[ -n "${TTS_PORT}" && -n "${tts_alias}" && -n "${TTS_MODEL}" ]]; then
        [[ -n "${out}" ]] && out="${out},"
        # Explicit upstream since mlx_audio.server has no --model flag for the
        # router to auto-detect via lsof+ps.
        out="${out}${tts_alias}=http://${MLX_HOST}:${TTS_PORT}|${TTS_MODEL}"
    fi
    # Extra TTS models share the same server; register one static per path so
    # the router can route by basename alias and rewrite the body's `model`
    # field to the upstream id mlx_audio.server expects.
    if [[ -n "${TTS_PORT}" && -n "${TTS_EXTRA_MODELS}" ]]; then
        local extra
        for extra in ${(s:,:)TTS_EXTRA_MODELS}; do
            extra="${extra## }"; extra="${extra%% }"
            [[ -z "${extra}" ]] && continue
            [[ -n "${out}" ]] && out="${out},"
            out="${out}${extra:t}=http://${MLX_HOST}:${TTS_PORT}|${extra}"
        done
    fi
    # Kokoro lives in its own mlx_audio.server on KOKORO_PORT.
    if [[ -n "${KOKORO_PORT}" && -n "${KOKORO_MODEL}" ]]; then
        [[ -n "${out}" ]] && out="${out},"
        out="${out}${KOKORO_MODEL:t}=http://${MLX_HOST}:${KOKORO_PORT}|${KOKORO_MODEL}"
    fi
    print -- "${out}"
}

_router_start() {
    [[ -f "${ROUTER_SCRIPT}" ]] || {
        print -u2 "ERROR: router script missing: ${ROUTER_SCRIPT}"
        return 1
    }
    local pidfile="${LOG_DIR}/${ROUTER_NAME}.pid"
    local log="${LOG_DIR}/${ROUTER_NAME}.log"
    if [[ -f "${pidfile}" ]] && kill -0 "$(<"${pidfile}")" 2>/dev/null; then
        print ">>> ${ROUTER_NAME} already running (pid $(<"${pidfile}"))"
        return 0
    fi
    local profiles statics
    profiles="$(_router_profile_csv)"
    statics="$(_router_statics_csv)"
    local ports="${ROUTER_PORT}"
    [[ -n "${ROUTER_EXTRA_PORTS}" ]] && ports="${ports}, ${ROUTER_EXTRA_PORTS}"
    print ">>> Starting ${ROUTER_NAME}"
    print "    listen:   ${ROUTER_HOST} on ports ${ports}"
    print "    backend:  http://${MLX_HOST}:${CHAT_PORT}"
    print "    profiles: ${profiles}"
    print "    statics:  ${statics:-(none)}"
    nohup env \
        ROUTER_HOST="${ROUTER_HOST}" \
        ROUTER_PORT="${ROUTER_PORT}" \
        ROUTER_EXTRA_PORTS="${ROUTER_EXTRA_PORTS}" \
        BACKEND_URL="http://${MLX_HOST}:${CHAT_PORT}" \
        ROUTER_PROFILES="${profiles}" \
        ROUTER_STATICS="${statics}" \
        ROUTER_SWITCH_TIMEOUT="${ROUTER_SWITCH_TIMEOUT}" \
        MLX_SERVERS_CMD="${MLX_SCRIPT_PATH}" \
        ROUTER_LOG_LEVEL="${ROUTER_LOG_LEVEL}" \
        "${MLX_PY}" "${ROUTER_SCRIPT}" >"${log}" 2>&1 &!
    print "$!" >"${pidfile}"
    print "    pid: $(<"${pidfile}")"
    print "    log: ${log}"
}

_router_stop() {
    stop_one "${ROUTER_NAME}"
}

_router_status() {
    local pidfile="${LOG_DIR}/${ROUTER_NAME}.pid"
    if [[ ! -f "${pidfile}" ]] || ! kill -0 "$(<"${pidfile}")" 2>/dev/null; then
        print "${_C_YELLOW}●${_C_RESET} ${_C_BOLD}${ROUTER_NAME}${_C_RESET} — inactive"
        return 0
    fi
    local pid="$(<"${pidfile}")"
    print "${_C_GREEN}●${_C_RESET} ${_C_BOLD}${ROUTER_NAME}${_C_RESET} — active"
    local ports="${ROUTER_PORT}"
    [[ -n "${ROUTER_EXTRA_PORTS}" ]] && ports="${ports}, ${ROUTER_EXTRA_PORTS}"
    printf "       %s%-9s%s %s\n" "${_C_DIM}" "Listen:"  "${_C_RESET}" "${ROUTER_HOST}:${ports}"
    printf "       %s%-9s%s %s\n" "${_C_DIM}" "Backend:" "${_C_RESET}" "http://${MLX_HOST}:${CHAT_PORT}"
    printf "       %s%-9s%s %s\n" "${_C_DIM}" "PID:"     "${_C_RESET}" "${pid}"
    # Live state from /router/health
    if command -v curl >/dev/null 2>&1; then
        local health
        health=$(curl -s --max-time 2 "http://${ROUTER_HOST}:${ROUTER_PORT}/router/health" 2>/dev/null)
        if [[ -n "${health}" ]]; then
            local loaded statics
            loaded=$(/usr/bin/python3 -c "import json,sys;print(json.loads(sys.stdin.read()).get('loaded_model') or '')" <<<"${health}" 2>/dev/null)
            [[ -n "${loaded}" ]] && printf "       %s%-9s%s %s\n" "${_C_DIM}" "Loaded:" "${_C_RESET}" "${loaded}"
            statics=$(/usr/bin/python3 -c "
import json, sys
data = json.loads(sys.stdin.read()).get('statics') or []
for s in data:
    flag = 'ok' if s.get('healthy') else 'down'
    print(f\"  {s['name']:14s} {flag:4s} {s['url']}  upstream={s.get('upstream_model') or '?'}\")
" <<<"${health}" 2>/dev/null)
            if [[ -n "${statics}" ]]; then
                printf "       %s%-9s%s\n" "${_C_DIM}" "Statics:" "${_C_RESET}"
                print -- "${statics}" | sed 's/^/     /'
            fi
        fi
    fi
}

cmd_router() {
    local sub="${1:-status}"
    (( $# )) && shift
    case "${sub}" in
        start)   _router_start "$@" ;;
        stop)    _router_stop  "$@" ;;
        restart) _router_stop; sleep 1; _router_start "$@" ;;
        status)  _router_status "$@" ;;
        log)     [[ -f "${LOG_DIR}/${ROUTER_NAME}.log" ]] && tail -f "${LOG_DIR}/${ROUTER_NAME}.log" || print -u2 "no log yet" ;;
        -h|--help|help)
            print "Usage: mlx router {start|stop|restart|status|log}"
            print
            print "OpenAI-compatible proxy that fronts the chat server (swap on \`model\` field)"
            print "plus the tags and embed servers (static passthrough). Aggregates /v1/models"
            print "across all three. Listens on \$ROUTER_PORT (default 8080); add more ports"
            print "via \$ROUTER_EXTRA_PORTS (comma-separated)."
            print
            print "Point SillyTavern's API URL at http://${ROUTER_HOST}:${ROUTER_PORT}/v1"
            print "and set \"model\" in your connection profile to one of the chat profiles:"
            local k
            for k in "${(@k)CHAT_MODEL_PROFILES}"; do print "  ${k}"; done | sort
            print
            print "Or one of the static aliases:"
            print "  ${ROUTER_TAGS_ALIAS:-${TAGS_MODEL:t}}  (tags, port ${TAGS_PORT})"
            print "  ${ROUTER_EMBED_ALIAS}  (embed, port ${EMBED_PORT})"
            ;;
        *) print -u2 "unknown router subcommand: ${sub}"; return 1 ;;
    esac
}

