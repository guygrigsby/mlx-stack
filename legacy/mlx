show_router_help() {
    cat <<EOF
OpenAI-compatible proxy that fronts the chat server (swap-on-demand by the
\`model\` field) plus static tags/embed/tts backends. Aggregates /v1/models
across all four so clients see the full catalog.

USAGE
    mlx router {start|stop|restart|status|log}

Listens on \$ROUTER_PORT (default ${ROUTER_PORT}); add more ports via
\$ROUTER_EXTRA_PORTS (comma-separated). Point SillyTavern's API URL at
http://${ROUTER_HOST}:${ROUTER_PORT}/v1 and set "model" to a chat profile
or one of the static aliases (tags, embed, tts).
EOF
}

cmd_help() {
    case "${1:-}" in
        start)   show_start_help ;;
        stop)    show_stop_help ;;
        restart) show_restart_help ;;
        status)  show_status_help ;;
        monitor) show_monitor_help ;;
        tail)    show_tail_help ;;
        config)  show_config_help ;;
        chat)    show_chat_help ;;
        tags)    show_tags_help ;;
        tag)     show_tag_help ;;
        embed)   show_embed_help ;;
        tts)     show_tts_help ;;
        kokoro)  show_kokoro_help ;;
        router)  show_router_help ;;
        ""|help) show_root_help ;;
        *) print -u2 "unknown command: $1"; show_root_help; return 1 ;;
    esac
}

# ============================================================================
# Dispatch
# ============================================================================
main() {
    local cmd="${1:-}"
    (( $# )) && shift

    case "${cmd}" in
        ""|-h|--help|help) cmd_help "$@" ;;
        start)   cmd_start   "$@" ;;
        stop)    cmd_stop    "$@" ;;
        restart) cmd_restart "$@" ;;
        status)  cmd_status  "$@" ;;
        monitor) cmd_monitor "$@" ;;
        tail)    cmd_tail    "$@" ;;
        config)  cmd_config  "$@" ;;
        chat)    cmd_chat    "$@" ;;
        tags)    cmd_tags    "$@" ;;
        tag)     cmd_tag     "$@" ;;
        router)  cmd_router  "$@" ;;
        *) print -u2 "unknown command: ${cmd}"; show_root_help; exit 1 ;;
    esac
}

main "$@"
