# ============================================================================
# Internals
# ============================================================================
verify_path() {
    local label="$1" path="$2"
    if [[ ! -d "${path}" ]]; then
        print -u2 "ERROR: ${label} not found at: ${path}"
        return 1
    fi
    if [[ ! -f "${path}/config.json" ]]; then
        print -u2 "ERROR: ${label} at ${path} is missing config.json"
        return 1
    fi
}

verify_mlx_bin() {
    if [[ ! -x "${MLX_PY}" ]]; then
        print -u2 "ERROR: venv python not found at ${MLX_PY}"
        print -u2 "       Set MLX_VENV (currently: ${MLX_VENV}) or install mlx-lm:"
        print -u2 "         python3 -m venv ${MLX_VENV} && ${MLX_VENV}/bin/pip install mlx-lm mlx-vlm"
        return 1
    fi
    if [[ ! -f "${MLX_LAUNCHER}" ]]; then
        print -u2 "ERROR: launcher shim not found at ${MLX_LAUNCHER}"
        print -u2 "       Set MLX_LAUNCHER or restore the file."
        return 1
    fi
}

# Verify the server module for one engine is importable. lm and vlm have
# separate pip packages; only fail if the engine the user actually configured
# is missing.
verify_engine() {
    local engine="$1"
    case "${engine}" in
        lm)
            if [[ ! -x "${MLX_LM_BIN}" ]]; then
                print -u2 "ERROR: mlx_lm.server not found at ${MLX_LM_BIN}"
                print -u2 "       Install with: ${MLX_VENV}/bin/pip install mlx-lm"
                return 1
            fi
            ;;
        vlm)
            if [[ ! -x "${MLX_VLM_BIN}" ]]; then
                print -u2 "ERROR: mlx_vlm.server not found at ${MLX_VLM_BIN}"
                print -u2 "       Install with: ${MLX_VENV}/bin/pip install mlx-vlm"
                return 1
            fi
            ;;
        *)
            print -u2 "ERROR: unknown engine '${engine}' (expected 'lm' or 'vlm')"
            return 1
            ;;
    esac
}

resolve_server() {
    case "$1" in
        chat|anubis|anubis-chat|"${CHAT_NAME}") print -- "${CHAT_NAME}" ;;
        tags|qwen|qwen-tags|"${TAGS_NAME}") print -- "${TAGS_NAME}" ;;
        embed|embeddings|"${EMBED_NAME}") print -- "${EMBED_NAME}" ;;
        tts|speech|audio|"${TTS_NAME}") print -- "${TTS_NAME}" ;;
        kokoro|"${KOKORO_NAME}") print -- "${KOKORO_NAME}" ;;
        all) print -- "all" ;;
        *) return 1 ;;
    esac
}

# Build server args for a server, picking the right flag set per engine.
# Result lands in global BUILT_ARGS.
# (zsh on this machine lacks namerefs, so we use a global instead.)
# Usage: build_server_args CHAT; <use BUILT_ARGS>
typeset -ga BUILT_ARGS=()
build_server_args() {
    local prefix="$1"
    BUILT_ARGS=()

    local model_var="${prefix}_MODEL"
    local port_var="${prefix}_PORT"
    local engine_var="${prefix}_ENGINE"
    local engine="${(P)engine_var:-lm}"

    BUILT_ARGS=(
        --model "${(P)model_var}"
        --host "${HOST}"
        --port "${(P)port_var}"
    )

    # Pick the flag tables for this engine.
    local -a opt_flags bool_flags
    case "${engine}" in
        vlm)
            opt_flags=("${VLM_OPTIONAL_FLAGS[@]}")
            bool_flags=("${VLM_BOOL_FLAGS[@]}")
            ;;
        *)
            opt_flags=("${OPTIONAL_FLAGS[@]}")
            bool_flags=("${BOOL_FLAGS[@]}")
            ;;
    esac

    local pair suffix flag var_name val
    for pair in "${opt_flags[@]}"; do
        suffix="${pair%%=*}"
        flag="${pair##*=}"
        var_name="${prefix}_${suffix}"
        val="${(P)var_name}"
        if [[ -n "${val}" ]]; then
            BUILT_ARGS+=("${flag}" "${val}")
        fi
    done

    for pair in "${bool_flags[@]}"; do
        suffix="${pair%%=*}"
        flag="${pair##*=}"
        var_name="${prefix}_${suffix}"
        if [[ "${(P)var_name}" == "1" ]]; then
            BUILT_ARGS+=("${flag}")
        fi
    done

    # mlx_vlm.server has no --allowed-origins; only mlx_lm.server takes it.
    if [[ "${engine}" != "vlm" ]] && [[ -n "${ALLOWED_ORIGINS}" ]]; then
        BUILT_ARGS+=(--allowed-origins "${ALLOWED_ORIGINS}")
    fi
}

# Build env-var pairs (NAME=VAL) for the launcher shim, scoped to one server.
# Result lands in global LAUNCH_ENV.
typeset -ga LAUNCH_ENV=()
typeset -ga LAUNCH_ENV_KEYS=(
    "CACHE_LIMIT_BYTES=MLX_CACHE_LIMIT_BYTES"
    "MEMORY_LIMIT_BYTES=MLX_MEMORY_LIMIT_BYTES"
    "CACHE_CLEAR_INTERVAL_SEC=MLX_CACHE_CLEAR_INTERVAL_SEC"
    "CACHE_CLEAR_THRESHOLD_BYTES=MLX_CACHE_CLEAR_THRESHOLD_BYTES"
    "MEMORY_LOG_INTERVAL_SEC=MLX_MEMORY_LOG_INTERVAL_SEC"
    "KV_HEADROOM_BYTES=MLX_KV_HEADROOM_BYTES"
    "ACTIVE_MEMORY_CHECK_INTERVAL_SEC=MLX_ACTIVE_MEMORY_CHECK_INTERVAL_SEC"
    "ACTIVE_MEMORY_GRACE_SEC=MLX_ACTIVE_MEMORY_GRACE_SEC"
)
build_launch_env() {
    local prefix="$1"
    LAUNCH_ENV=()

    # Engine selector for the launcher shim (selects mlx_lm vs mlx_vlm).
    local engine_var="${prefix}_ENGINE"
    local engine="${(P)engine_var:-lm}"
    LAUNCH_ENV+=("MLX_ENGINE=${engine}")

    local pair suffix envname var_name val
    for pair in "${LAUNCH_ENV_KEYS[@]}"; do
        suffix="${pair%%=*}"
        envname="${pair##*=}"
        var_name="${prefix}_${suffix}"
        val="${(P)var_name}"
        if [[ -n "${val}" ]]; then
            LAUNCH_ENV+=("${envname}=${val}")
        fi
    done
}

launch() {
    local name="$1"; shift
    local pidfile="${LOG_DIR}/${name}.pid"
    local log="${LOG_DIR}/${name}.log"

    if [[ -f "${pidfile}" ]] && kill -0 "$(<"${pidfile}")" 2>/dev/null; then
        print ">>> ${name} already running (pid $(<"${pidfile}"))"
        return 0
    fi

    print ">>> Starting ${name}"
    nohup env "${LAUNCH_ENV[@]}" "${MLX_PY}" "${MLX_LAUNCHER}" "$@" >"${log}" 2>&1 &!
    print "$!" >"${pidfile}"
    print "    pid: $(<"${pidfile}")"
    print "    log: ${log}"
}

stop_one() {
    local name="$1"
    local pidfile="${LOG_DIR}/${name}.pid"
    if [[ ! -f "${pidfile}" ]]; then
        print "<<< ${name} not running"
        return 0
    fi
    local pid
    pid="$(<"${pidfile}")"
    if kill -0 "${pid}" 2>/dev/null; then
        print "<<< Stopping ${name} (pid ${pid})"
        kill "${pid}"
        sleep 1
        if kill -0 "${pid}" 2>/dev/null; then
            print "    still alive, sending SIGKILL"
            kill -9 "${pid}" 2>/dev/null || true
        fi
    else
        print "<<< ${name} not running (stale pid ${pid})"
    fi
    rm -f "${pidfile}"
}

