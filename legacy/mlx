# Resolve the chat model + draft + engine from profile name, with this
# precedence:
#   1. CHAT_PROFILE (set by --chat-model flag or env var)
#   2. CHAT_PROFILE_DEFAULT (config file)
#   3. existing CHAT_MODEL value (legacy escape hatch; no profile lookup)
# Sets CHAT_MODEL, CHAT_DRAFT_MODEL, and CHAT_ENGINE when a profile is
# selected. Empty draft entry disables spec-dec. Missing engine entry falls
# back to the global CHAT_ENGINE (default 'lm').
resolve_chat_profile() {
    local profile="${CHAT_PROFILE:-${CHAT_PROFILE_DEFAULT}}"
    [[ -z "${profile}" ]] && return 0
    if [[ -z "${CHAT_MODEL_PROFILES[$profile]+x}" ]]; then
        print -u2 "ERROR: unknown chat profile '${profile}'. Known profiles:"
        local k
        for k in "${(@k)CHAT_MODEL_PROFILES}"; do
            print -u2 "  ${k}  ->  ${CHAT_MODEL_PROFILES[$k]}"
        done
        return 1
    fi
    CHAT_MODEL="${CHAT_MODEL_PROFILES[$profile]}"
    CHAT_DRAFT_MODEL="${CHAT_DRAFT_PROFILES[$profile]:-}"
    local engine_override="${CHAT_ENGINE_PROFILES[$profile]:-}"
    [[ -n "${engine_override}" ]] && CHAT_ENGINE="${engine_override}"
    CHAT_PROFILE="${profile}"
}

launch_embed() {
    local pidfile="${LOG_DIR}/${EMBED_NAME}.pid"
    local log="${LOG_DIR}/${EMBED_NAME}.log"

    if [[ -f "${pidfile}" ]] && kill -0 "$(<"${pidfile}")" 2>/dev/null; then
        print ">>> ${EMBED_NAME} already running (pid $(<"${pidfile}"))"
        return 0
    fi
    if [[ ! -f "${EMBED_SCRIPT}" ]]; then
        print -u2 "ERROR: embed server script not found at ${EMBED_SCRIPT}"
        return 1
    fi

    print ">>> Starting ${EMBED_NAME}"
    print "    model: ${EMBED_MODEL}"
    print "    port:  ${EMBED_PORT}"
    nohup "${MLX_PY}" "${EMBED_SCRIPT}" \
        --model "${EMBED_MODEL}" \
        --host "${HOST}" \
        --port "${EMBED_PORT}" \
        >"${log}" 2>&1 &!
    print "$!" >"${pidfile}"
    print "    pid:   $(<"${pidfile}")"
    print "    log:   ${log}"
}

# Generic mlx_audio.server launcher used by both TTS and Kokoro.
# Args: name port bin primary_model extra_models_csv
launch_audio() {
    local name="$1" port="$2" bin="$3" primary="$4" extras_csv="$5"
    local pidfile="${LOG_DIR}/${name}.pid"
    local log="${LOG_DIR}/${name}.log"

    if [[ -f "${pidfile}" ]] && kill -0 "$(<"${pidfile}")" 2>/dev/null; then
        print ">>> ${name} already running (pid $(<"${pidfile}"))"
        return 0
    fi
    if [[ ! -x "${bin}" ]]; then
        print -u2 "ERROR: audio binary not found or not executable: ${bin}"
        print -u2 "       install with: ${MLX_VENV}/bin/pip install mlx-audio webrtcvad python-multipart"
        return 1
    fi
    verify_path "${name} model" "${primary}" || return 1

    print ">>> Starting ${name}"
    print "    model: ${primary}"
    print "    port:  ${port}"
    nohup "${bin}" \
        --host "${HOST}" \
        --port "${port}" \
        >"${log}" 2>&1 &!
    print "$!" >"${pidfile}"
    print "    pid:   $(<"${pidfile}")"
    print "    log:   ${log}"

    # Preload primary model plus any extras so the first request doesn't pay
    # the load tax. mlx_audio.server takes the model via query param on
    # POST /v1/models. Each model is sent as its own POST; all stay resident.
    if command -v curl >/dev/null 2>&1; then
        local tries=0
        while (( tries < 30 )); do
            if curl -s --max-time 1 -o /dev/null \
                "http://${HOST}:${port}/v1/models"; then
                local -a preload_models=("${primary}")
                if [[ -n "${extras_csv}" ]]; then
                    local m
                    for m in ${(s:,:)extras_csv}; do
                        m="${m## }"; m="${m%% }"
                        [[ -n "${m}" ]] && preload_models+=("${m}")
                    done
                fi
                local model url
                for model in "${preload_models[@]}"; do
                    url=$(/usr/bin/python3 -c \
                        "import urllib.parse, sys; print(urllib.parse.quote(sys.argv[1], safe=''))" \
                        "${model}")
                    curl -s --max-time 5 -X POST \
                        "http://${HOST}:${port}/v1/models?model_name=${url}" \
                        >/dev/null 2>&1 &!
                done
                print "    preload submitted (background): ${#preload_models[@]} model(s)"
                break
            fi
            sleep 0.5
            (( ++tries ))
        done
    fi
}

launch_tts() {
    launch_audio "${TTS_NAME}" "${TTS_PORT}" "${TTS_BIN}" \
        "${TTS_MODEL}" "${TTS_EXTRA_MODELS}"
}

launch_kokoro() {
    launch_audio "${KOKORO_NAME}" "${KOKORO_PORT}" "${KOKORO_BIN}" \
        "${KOKORO_MODEL}" ""
}

cmd_start() {
    local skip_chat=0 skip_tags=0 skip_embed=0 skip_tts=0 skip_kokoro=0
    while (( $# )); do
        case "$1" in
            -h|--help) show_start_help; return 0 ;;
            --no-chat) skip_chat=1; shift ;;
            --no-tags) skip_tags=1; shift ;;
            --no-embed) skip_embed=1; shift ;;
            --no-tts) skip_tts=1; shift ;;
            --no-kokoro) skip_kokoro=1; shift ;;
            --chat-port) CHAT_PORT="$2"; shift 2 ;;
            --chat-port=*) CHAT_PORT="${1#*=}"; shift ;;
            --tags-port) TAGS_PORT="$2"; shift 2 ;;
            --tags-port=*) TAGS_PORT="${1#*=}"; shift ;;
            --embed-port) EMBED_PORT="$2"; shift 2 ;;
            --embed-port=*) EMBED_PORT="${1#*=}"; shift ;;
            --tts-port) TTS_PORT="$2"; shift 2 ;;
            --tts-port=*) TTS_PORT="${1#*=}"; shift ;;
            --kokoro-port) KOKORO_PORT="$2"; shift 2 ;;
            --kokoro-port=*) KOKORO_PORT="${1#*=}"; shift ;;
            --draft-tokens) CHAT_NUM_DRAFT_TOKENS="$2"; shift 2 ;;
            --draft-tokens=*) CHAT_NUM_DRAFT_TOKENS="${1#*=}"; shift ;;
            --chat-model) CHAT_PROFILE="$2"; shift 2 ;;
            --chat-model=*) CHAT_PROFILE="${1#*=}"; shift ;;
            *) print -u2 "unknown flag: $1"; show_start_help; return 1 ;;
        esac
    done

    if (( ! skip_chat )); then
        resolve_chat_profile || return 1
        print "chat profile: ${CHAT_PROFILE}  model: ${CHAT_MODEL}  draft: ${CHAT_DRAFT_MODEL:-<none>}"
    fi

    verify_mlx_bin || return 1
    if (( ! skip_chat )); then
        verify_engine "${CHAT_ENGINE}" || return 1
        verify_path "chat model" "${CHAT_MODEL}" || return 1
        [[ -n "${CHAT_DRAFT_MODEL}" ]] && [[ "${CHAT_ENGINE}" == "lm" ]] && { verify_path "chat draft model" "${CHAT_DRAFT_MODEL}" || return 1 }
        [[ -n "${CHAT_ADAPTER_PATH}" ]] && { verify_path "chat adapter" "${CHAT_ADAPTER_PATH}" || return 1 }
    fi
    if (( ! skip_tags )); then
        verify_engine "${TAGS_ENGINE}" || return 1
        verify_path "tags model" "${TAGS_MODEL}" || return 1
        [[ -n "${TAGS_DRAFT_MODEL}" ]] && [[ "${TAGS_ENGINE}" == "lm" ]] && { verify_path "tags draft model" "${TAGS_DRAFT_MODEL}" || return 1 }
        [[ -n "${TAGS_ADAPTER_PATH}" ]] && { verify_path "tags adapter" "${TAGS_ADAPTER_PATH}" || return 1 }
    fi

    if (( ! skip_chat )); then
        build_server_args CHAT
        build_launch_env CHAT
        launch "${CHAT_NAME}" "${BUILT_ARGS[@]}"
    fi
    if (( ! skip_tags )); then
        build_server_args TAGS
        build_launch_env TAGS
        launch "${TAGS_NAME}" "${BUILT_ARGS[@]}"
    fi
    if (( ! skip_embed )); then
        launch_embed
    fi
    if (( ! skip_tts )); then
        launch_tts
    fi
    if (( ! skip_kokoro )); then
        launch_kokoro
    fi

    print
    print "Endpoints:"
    (( ! skip_chat ))   && print "  chat:   http://${HOST}:${CHAT_PORT}/v1   (k=${CHAT_NUM_DRAFT_TOKENS})"
    (( ! skip_tags ))   && print "  tags:   http://${HOST}:${TAGS_PORT}/v1"
    (( ! skip_embed ))  && print "  embed:  http://${HOST}:${EMBED_PORT}/v1/embeddings"
    (( ! skip_tts ))    && print "  tts:    http://${HOST}:${TTS_PORT}/v1/audio/speech"
    (( ! skip_kokoro )) && print "  kokoro: http://${HOST}:${KOKORO_PORT}/v1/audio/speech"
}

cmd_stop() {
    local target="all"
    while (( $# )); do
        case "$1" in
            -h|--help) show_stop_help; return 0 ;;
            -*) print -u2 "unknown flag: $1"; show_stop_help; return 1 ;;
            *)
                target=$(resolve_server "$1") || { print -u2 "unknown server: $1"; show_stop_help; return 1 }
                shift
                ;;
        esac
    done

    case "${target}" in
        "${CHAT_NAME}") stop_one "${CHAT_NAME}" ;;
        "${TAGS_NAME}") stop_one "${TAGS_NAME}" ;;
        "${EMBED_NAME}") stop_one "${EMBED_NAME}" ;;
        "${TTS_NAME}") stop_one "${TTS_NAME}" ;;
        "${KOKORO_NAME}") stop_one "${KOKORO_NAME}" ;;
        all) stop_one "${CHAT_NAME}"; stop_one "${TAGS_NAME}"; stop_one "${EMBED_NAME}"; stop_one "${TTS_NAME}"; stop_one "${KOKORO_NAME}" ;;
    esac
}

cmd_restart() {
    local target="all"
    local args=()
    local start_extra=()
    while (( $# )); do
        case "$1" in
            -h|--help) show_restart_help; return 0 ;;
            --chat-model) start_extra+=("$1" "$2"); shift 2 ;;
            --chat-model=*) start_extra+=("$1"); shift ;;
            --embed-port) EMBED_PORT="$2"; shift 2 ;;
            --embed-port=*) EMBED_PORT="${1#*=}"; shift ;;
            -*) print -u2 "unknown flag: $1"; show_restart_help; return 1 ;;
            *)
                target=$(resolve_server "$1") || { print -u2 "unknown server: $1"; show_restart_help; return 1 }
                args+=("$1")
                shift
                ;;
        esac
    done

    if (( ${#args} > 0 )); then
        cmd_stop "${args[@]}"
    else
        cmd_stop
    fi
    sleep 1

    case "${target}" in
        "${CHAT_NAME}") cmd_start --no-tags --no-embed --no-tts --no-kokoro "${start_extra[@]}" ;;
        "${TAGS_NAME}") cmd_start --no-chat --no-embed --no-tts --no-kokoro "${start_extra[@]}" ;;
        "${EMBED_NAME}") cmd_start --no-chat --no-tags --no-tts --no-kokoro "${start_extra[@]}" ;;
        "${TTS_NAME}") cmd_start --no-chat --no-tags --no-embed --no-kokoro "${start_extra[@]}" ;;
        "${KOKORO_NAME}") cmd_start --no-chat --no-tags --no-embed --no-tts "${start_extra[@]}" ;;
        all) cmd_start "${start_extra[@]}" ;;
    esac
}

_format_kb() {
    local kb="${1:-0}"
    if (( kb >= 1048576 )); then
        printf "%.2f GB" $(( kb / 1048576.0 ))
    elif (( kb >= 1024 )); then
        printf "%.1f MB" $(( kb / 1024.0 ))
    else
        printf "%d KB" "${kb}"
    fi
}

# Read MLX active memory from the launcher's periodic mem snapshot in the log.
# RSS chronically undercounts mlx models because weights live in Metal/unified
# memory pools that don't fault into the process page tables — for VLM models
# the gap can be 30x. The launcher shim writes lines like:
#   [mlx-launch] mem: active=17.99 GB cache=0.00 GB peak=19.86 GB
# This is the truth; we parse and prefer it over RSS when available.
# Returns: bytes (integer), or empty string if no mem line found.
_mlx_active_bytes() {
    setopt local_options no_err_return
    local log="${1:-}"
    [[ -z "${log}" ]] || [[ ! -f "${log}" ]] && return 0
    local line
    line=$(grep "\[mlx-launch\] mem:" "${log}" 2>/dev/null | tail -1)
    [[ -z "${line}" ]] && return 0
    # Parse "active=X.XX GB" -> bytes
    /usr/bin/python3 -c "
import re, sys
m = re.search(r'active=([\d.]+)\s*(GB|MB|KB)', sys.argv[1])
if not m:
    sys.exit(0)
val = float(m.group(1))
unit = m.group(2)
mult = {'GB': 1024**3, 'MB': 1024**2, 'KB': 1024}[unit]
print(int(val * mult))
" "${line}" 2>/dev/null
    return 0
}

# Sum RSS across a process and all its descendants. Kept for fallback when
# no mlx-launch mem line is available in the log yet (e.g. server just started).
_rss_tree_kb() {
    setopt local_options no_err_return
    local root_pid="${1:-}"
    if [[ -z "${root_pid}" ]]; then print -- 0; return 0; fi
    # Walk the process tree using BSD ps. Build a set of all descendant PIDs.
    local total=0 pid kb
    local descendants
    descendants=$(/usr/bin/python3 -c "
import subprocess, sys
root = int(sys.argv[1])
out = subprocess.run(['ps', '-axo', 'pid=,ppid='], capture_output=True, text=True).stdout
parent = {}
for line in out.splitlines():
    parts = line.split()
    if len(parts) == 2:
        try:
            p, pp = int(parts[0]), int(parts[1])
        except ValueError:
            continue
        parent.setdefault(pp, []).append(p)
all_pids = [root]
i = 0
while i < len(all_pids):
    for child in parent.get(all_pids[i], []):
        if child not in all_pids:
            all_pids.append(child)
    i += 1
print(' '.join(str(p) for p in all_pids))
" "${root_pid}" 2>/dev/null)
    [[ -z "${descendants}" ]] && descendants="${root_pid}"
    for pid in ${=descendants}; do
        kb=$(ps -p "${pid}" -o rss= 2>/dev/null | tr -d ' ')
        if [[ -n "${kb}" ]] && [[ "${kb}" =~ ^[0-9]+$ ]]; then
            (( total = total + kb ))
        fi
    done
    print -- "${total}"
    return 0
}

# ANSI colors. Disabled when stdout isn't a TTY (e.g. piping into less).
if [[ -t 1 ]]; then
    _C_GREEN=$'\e[0;32m'
    _C_RED=$'\e[0;31m'
    _C_YELLOW=$'\e[0;33m'
    _C_DIM=$'\e[2m'
    _C_BOLD=$'\e[1m'
    _C_RESET=$'\e[0m'
else
    _C_GREEN="" _C_RED="" _C_YELLOW="" _C_DIM="" _C_BOLD="" _C_RESET=""
fi

# Print a systemd-style status block for one server.
# Args: name port description tail_lines
_status_one() {
    local name="$1" port="$2" desc="$3" tail_lines="${4:-0}"
    local pidfile="${LOG_DIR}/${name}.pid"
    local log="${LOG_DIR}/${name}.log"

    local pid="" state dot_color
    if [[ -f "${pidfile}" ]]; then
        pid="$(<"${pidfile}")"
        if kill -0 "${pid}" 2>/dev/null; then
            state="${_C_GREEN}active (running)${_C_RESET}"
            dot_color="${_C_GREEN}"
        else
            state="${_C_RED}dead${_C_RESET} ${_C_DIM}(stale pid ${pid})${_C_RESET}"
            dot_color="${_C_RED}"
            pid=""
            return 1
        fi
    else
        state="${_C_YELLOW}inactive${_C_RESET} ${_C_DIM}(not started)${_C_RESET}"
        dot_color="${_C_YELLOW}"
        return 1
    fi 2>/dev/null

    # Print header even if we returned non-zero above; we want the visible block.
    print -- "${dot_color}●${_C_RESET} ${_C_BOLD}${name}${_C_RESET} — ${desc}"
    printf "       %s%-9s%s %s\n" "${_C_DIM}" "Status:" "${_C_RESET}" "${state}"
    printf "       %s%-9s%s %s\n" "${_C_DIM}" "Port:"   "${_C_RESET}" "${port}"
    printf "       %s%-9s%s %s\n" "${_C_DIM}" "Log:"    "${_C_RESET}" "${log}"

    if [[ -n "${pid}" ]]; then
        local rss_kb cpu_time elapsed since rss_human mlx_bytes mem_line
        rss_kb=$(_rss_tree_kb "${pid}")
        cpu_time=$(ps -p "${pid}" -o time= 2>/dev/null | tr -d ' ')
        since=$(ps -p "${pid}" -o lstart= 2>/dev/null | sed 's/  */ /g; s/^ //; s/ *$//')
        elapsed=$(ps -p "${pid}" -o etime= 2>/dev/null | tr -d ' ')
        rss_human=$(_format_kb "${rss_kb}")

        # Prefer the launcher's MLX active-memory log when available; that's
        # the truth for Metal/unified-memory allocations. Fall back to RSS.
        mlx_bytes=$(_mlx_active_bytes "${log}")
        if [[ -n "${mlx_bytes}" ]] && (( mlx_bytes > 0 )); then
            mem_line=$(printf "%.2f GB active (Metal) ${_C_DIM}/ %s resident${_C_RESET}" \
                $(( mlx_bytes / 1073741824.0 )) "${rss_human}")
        else
            mem_line="${rss_human} resident"
        fi

        printf "       %s%-9s%s %s\n" "${_C_DIM}" "PID:"    "${_C_RESET}" "${pid}"
        printf "       %s%-9s%s %s\n" "${_C_DIM}" "Memory:" "${_C_RESET}" "${mem_line}"
        printf "       %s%-9s%s %s\n" "${_C_DIM}" "CPU:"    "${_C_RESET}" "${cpu_time}"
        printf "       %s%-9s%s %s ${_C_DIM}(%s ago)${_C_RESET}\n" "${_C_DIM}" "Since:" "${_C_RESET}" "${since}" "${elapsed}"

        if (( tail_lines > 0 )) && [[ -f "${log}" ]]; then
            print -- "       ${_C_DIM}Recent log:${_C_RESET}"
            tail -n "${tail_lines}" "${log}" 2>/dev/null | sed "s/^/         ${_C_DIM}>${_C_RESET} /"
        fi
    fi
}

_status_short_one() {
    local name="$1" port="$2"
    local pidfile="${LOG_DIR}/${name}.pid"
    local log="${LOG_DIR}/${name}.log"
    local state_word state_color pid="" mem="-"
    local rc=0

    if [[ -f "${pidfile}" ]] && kill -0 "$(<"${pidfile}")" 2>/dev/null; then
        pid="$(<"${pidfile}")"
        state_word="up"
        state_color="${_C_GREEN}"
    else
        state_word="down"
        state_color="${_C_RED}"
        rc=1
    fi

    if [[ -n "${pid}" ]]; then
        local rss_kb mlx_bytes
        rss_kb=$(_rss_tree_kb "${pid}")
        mlx_bytes=$(_mlx_active_bytes "${log}")
        if [[ -n "${mlx_bytes}" ]] && (( mlx_bytes > 0 )); then
            mem=$(printf "%.2f GB active" $(( mlx_bytes / 1073741824.0 )))
        else
            mem="$(_format_kb "${rss_kb}") resident"
        fi
    fi

    printf "%-9s %s%-4s%s  %-5s %s\n" \
        "${name}" "${state_color}" "${state_word}" "${_C_RESET}" "${port}" "${mem}"
    return $rc
}

cmd_status() {
    local quiet=0 short=0 tail_lines=5
    while (( $# )); do
        case "$1" in
            -h|--help) show_status_help; return 0 ;;
            -q|--quiet) quiet=1; shift ;;
            -s|--short) short=1; shift ;;
            -n|--no-log) tail_lines=0; shift ;;
            -l|--log-lines) tail_lines="$2"; shift 2 ;;
            -l=*|--log-lines=*) tail_lines="${1#*=}"; shift ;;
            *) print -u2 "unknown flag: $1"; show_status_help; return 1 ;;
        esac
    done

    if (( quiet )); then
        local rc=0 name pidfile
        for name in "${CHAT_NAME}" "${TAGS_NAME}" "${EMBED_NAME}" "${TTS_NAME}" "${KOKORO_NAME}"; do
            pidfile="${LOG_DIR}/${name}.pid"
            if [[ ! -f "${pidfile}" ]] || ! kill -0 "$(<"${pidfile}")" 2>/dev/null; then
                rc=1
            fi
        done
        return $rc
    fi

    if (( short )); then
        local rc=0
        _status_short_one "${CHAT_NAME}"   "${CHAT_PORT}"   || rc=1
        _status_short_one "${TAGS_NAME}"   "${TAGS_PORT}"   || rc=1
        _status_short_one "${EMBED_NAME}"  "${EMBED_PORT}"  || rc=1
        _status_short_one "${TTS_NAME}"    "${TTS_PORT}"    || rc=1
        _status_short_one "${KOKORO_NAME}" "${KOKORO_PORT}" || rc=1
        return $rc
    fi

    local rc=0
    _status_one "${CHAT_NAME}" "${CHAT_PORT}" \
        "$(_describe_server "${CHAT_NAME}" "lm/vlm chat")" \
        "${tail_lines}" || rc=1
    _print_chat_profiles
    print
    _status_one "${TAGS_NAME}" "${TAGS_PORT}" \
        "$(_describe_server "${TAGS_NAME}" "image tagging")" \
        "${tail_lines}" || rc=1
    print
    _status_one "${EMBED_NAME}" "${EMBED_PORT}" \
        "embeddings: ${EMBED_MODEL:t}" \
        "${tail_lines}" || rc=1
    print
    _status_one "${TTS_NAME}" "${TTS_PORT}" \
        "tts: ${TTS_MODEL:t}" \
        "${tail_lines}" || rc=1
    print
    _status_one "${KOKORO_NAME}" "${KOKORO_PORT}" \
        "kokoro: ${KOKORO_MODEL:t}" \
        "${tail_lines}" || rc=1
    return $rc
}

# List all registered chat profiles, marking which one is loaded by reading
# --model from the running chat process. Skipped silently if no profiles
# are registered (i.e., legacy single-model setup).
_print_chat_profiles() {
    (( ${#CHAT_MODEL_PROFILES} == 0 )) && return
    local pidfile="${LOG_DIR}/${CHAT_NAME}.pid" loaded_path=""
    if [[ -f "${pidfile}" ]]; then
        local pid
        pid="$(<"${pidfile}")"
        if kill -0 "${pid}" 2>/dev/null; then
            local cmd
            cmd="$(ps -p "${pid}" -o command= 2>/dev/null)"
            loaded_path="${cmd##*--model }"
            loaded_path="${loaded_path%% *}"
        fi
    fi
    print -- "       ${_C_DIM}Profiles:${_C_RESET}"
    local k mark
    for k in "${(@k)CHAT_MODEL_PROFILES}"; do
        if [[ "${CHAT_MODEL_PROFILES[$k]}" == "${loaded_path}" ]]; then
            mark="${_C_GREEN}● loaded${_C_RESET}"
        else
            mark="${_C_DIM}  available${_C_RESET}"
        fi
        printf "         %s %-12s %s\n" "${mark}" "${k}" "${CHAT_MODEL_PROFILES[$k]}"
    done
}

# Build a one-line description of the server from its live command line.
# Reads --model from the running process and emits the symlink alias under
# MODELS_ROOT (e.g. "anubis", "eva", "qwen-tags"). Falls back to the static
# label when the process isn't running.
_describe_server() {
    local name="$1" fallback="$2"
    local pidfile="${LOG_DIR}/${name}.pid"
    [[ -f "${pidfile}" ]] || { print -- "${fallback}"; return; }
    local pid
    pid="$(<"${pidfile}")"
    kill -0 "${pid}" 2>/dev/null || { print -- "${fallback}"; return; }
    local cmd
    cmd="$(ps -p "${pid}" -o command= 2>/dev/null)"
    local model="${cmd##*--model }"
    model="${model%% *}"
    [[ -z "${model}" ]] && { print -- "${fallback}"; return; }
    print -- "model: ${model:t}"
}

cmd_monitor() {
    local interval=5 count=0 csv=0
    while (( $# )); do
        case "$1" in
            -h|--help) show_monitor_help; return 0 ;;
            -i|--interval) interval="$2"; shift 2 ;;
            -i=*|--interval=*) interval="${1#*=}"; shift ;;
            -n|--count) count="$2"; shift 2 ;;
            -n=*|--count=*) count="${1#*=}"; shift ;;
            --csv) csv=1; shift ;;
            *) print -u2 "unknown flag: $1"; show_monitor_help; return 1 ;;
        esac
    done

    local chat_pid="" tags_pid=""
    [[ -f "${LOG_DIR}/${CHAT_NAME}.pid" ]] && chat_pid="$(<"${LOG_DIR}/${CHAT_NAME}.pid")"
    [[ -f "${LOG_DIR}/${TAGS_NAME}.pid" ]] && tags_pid="$(<"${LOG_DIR}/${TAGS_NAME}.pid")"
    [[ -n "${chat_pid}" ]] && kill -0 "${chat_pid}" 2>/dev/null || chat_pid=""
    [[ -n "${tags_pid}" ]] && kill -0 "${tags_pid}" 2>/dev/null || tags_pid=""

    if [[ -z "${chat_pid}" && -z "${tags_pid}" ]]; then
        print -u2 "no servers running. start one with 'mlx start'"
        return 1
    fi

    local chat_base_kb=0 tags_base_kb=0
    [[ -n "${chat_pid}"   ]] && chat_base_kb=$(_rss_tree_kb "${chat_pid}")
    [[ -n "${tags_pid}" ]] && tags_base_kb=$(_rss_tree_kb "${tags_pid}")

    if (( csv )); then
        print "timestamp,chat_pid,chat_rss_mb,chat_delta_mb,tags_pid,tags_rss_mb,tags_delta_mb"
    else
        printf "%-19s  %-22s  %-22s\n" "time" "chat (RSS / Δ)" "tags (RSS / Δ)"
        printf "%-19s  %-22s  %-22s\n" "-------------------" "----------------------" "----------------------"
    fi

    local n=0
    while :; do
        local ts chat_kb=0 tags_kb=0 chat_delta_mb=0 tags_delta_mb=0
        ts=$(date "+%Y-%m-%d %H:%M:%S")

        if [[ -n "${chat_pid}" ]] && kill -0 "${chat_pid}" 2>/dev/null; then
            chat_kb=$(_rss_tree_kb "${chat_pid}")
            (( chat_delta_mb = (chat_kb - chat_base_kb) / 1024 ))
        else
            chat_pid=""
        fi
        if [[ -n "${tags_pid}" ]] && kill -0 "${tags_pid}" 2>/dev/null; then
            tags_kb=$(_rss_tree_kb "${tags_pid}")
            (( tags_delta_mb = (tags_kb - tags_base_kb) / 1024 ))
        else
            tags_pid=""
        fi

        if (( csv )); then
            printf "%s,%s,%.1f,%d,%s,%.1f,%d\n" \
                "${ts}" \
                "${chat_pid:-}"   $(( chat_kb   / 1024.0 )) "${chat_delta_mb}" \
                "${tags_pid:-}" $(( tags_kb / 1024.0 )) "${tags_delta_mb}"
        else
            local chat_str tags_str
            if [[ -n "${chat_pid}" ]]; then
                chat_str="$(_format_kb "${chat_kb}") / $(_format_signed_mb "${chat_delta_mb}")"
            else
                chat_str="${_C_DIM}stopped${_C_RESET}"
            fi
            if [[ -n "${tags_pid}" ]]; then
                tags_str="$(_format_kb "${tags_kb}") / $(_format_signed_mb "${tags_delta_mb}")"
            else
                tags_str="${_C_DIM}stopped${_C_RESET}"
            fi
            printf "%-19s  %-22s  %-22s\n" "${ts}" "${chat_str}" "${tags_str}"
        fi

        if [[ -z "${chat_pid}" && -z "${tags_pid}" ]]; then
            print -u2 "all servers stopped"
            return 1
        fi

        (( ++n ))   # pre-increment: returns NEW value (truthy 1+); post-increment
                    # would return 0 first iter, false under err_return, would abort.
        if (( count > 0 && n >= count )); then
            return 0
        fi
        sleep "${interval}"
    done
}

# Format a signed MB delta (e.g. "+312 MB" / "-48 MB" / "0 MB").
_format_signed_mb() {
    local mb="${1:-0}"
    if (( mb > 0 )); then
        printf "+%d MB" "${mb}"
    elif (( mb < 0 )); then
        printf "%d MB" "${mb}"
    else
        print "0 MB"
    fi
}

