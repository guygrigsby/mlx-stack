#!/usr/bin/env zsh
# mlx — manage local MLX inference servers (chat + image tag gen)
#
# Configuration: ~/.config/mlx.conf (created on first install).
# Run "mlx help" or "mlx <command> --help" for usage.

emulate -LR zsh
setopt err_return pipe_fail

# Resolve our own absolute script path at top-level. Inside functions zsh's
# default function_argzero makes $0 the function name, so capturing here is
# the only way to hand the real path to subprocesses (e.g. the router exec'ing
# us back to swap chat models).
MLX_SCRIPT_PATH="${0:A}"

# ============================================================================
# Config file (sourced first; values here override built-in defaults but env
# vars and command flags still win)
# ============================================================================
MLX_CONFIG_FILE="${MLX_CONFIG_FILE:-${HOME}/.config/mlx.conf}"
if [[ -f "${MLX_CONFIG_FILE}" ]]; then
    source "${MLX_CONFIG_FILE}"
fi

# ============================================================================
# Defaults
# ============================================================================
: "${MLX_VENV:=${HOME}/venvs/mlx}"
: "${MLX_LAUNCHER:=${HOME}/scripts/mlx-server-launch.py}"
: "${MODELS_ROOT:=${HOME}/mlx-models}"
: "${MLX_LOG_DIR:=${HOME}/.logs/mlx}"
: "${MLX_HOST:=127.0.0.1}"
: "${ALLOWED_ORIGINS:=}"

# Cache/memory controls applied per-server by the launcher shim. Empty = off.
# Defaults are conservative auto-protection: cap allocator pool, periodically
# clear it, log mem snapshots. Override per-server in mlx.conf.
: "${CHAT_CACHE_LIMIT_BYTES:=2147483648}"             # 2 GB pool cap
: "${CHAT_MEMORY_LIMIT_BYTES:=}"                       # empty = no hard cap
: "${CHAT_CACHE_CLEAR_INTERVAL_SEC:=60}"
: "${CHAT_CACHE_CLEAR_THRESHOLD_BYTES:=1073741824}"   # 1 GB
: "${CHAT_MEMORY_LOG_INTERVAL_SEC:=300}"               # 5 min snapshots
: "${TAGS_CACHE_LIMIT_BYTES:=1073741824}"           # 1 GB pool cap
: "${TAGS_MEMORY_LIMIT_BYTES:=}"
: "${TAGS_CACHE_CLEAR_INTERVAL_SEC:=60}"
: "${TAGS_CACHE_CLEAR_THRESHOLD_BYTES:=536870912}"  # 512 MB
: "${TAGS_MEMORY_LOG_INTERVAL_SEC:=300}"

# Active-memory watchdog: execv-restart when active MLX memory grows past
# (model-loaded baseline + KV_HEADROOM_BYTES). The launcher captures the
# baseline automatically at the end of the grace period — you only set the
# cache headroom you'll tolerate above the model. Defends against unbounded
# prompt-cache growth (mlx_lm bug). Empty = disabled.
: "${CHAT_KV_HEADROOM_BYTES:=8000000000}"                   # 8 GB above model weights
: "${CHAT_ACTIVE_MEMORY_CHECK_INTERVAL_SEC:=30}"
: "${CHAT_ACTIVE_MEMORY_GRACE_SEC:=90}"                     # exempt first 90s; baseline captured at end
: "${TAGS_KV_HEADROOM_BYTES:=4000000000}"                   # 4 GB above model weights
: "${TAGS_ACTIVE_MEMORY_CHECK_INTERVAL_SEC:=60}"
: "${TAGS_ACTIVE_MEMORY_GRACE_SEC:=90}"

# Router: optional in-front proxy that fronts the chat backend (swap-on-demand
# by `model` field) plus the tags and embed backends (static passthrough).
# Aggregates /v1/models across all three so clients see the full catalog.
# Disabled by default; turn on with `mlx router start`.
: "${ROUTER_NAME:=router}"
: "${ROUTER_HOST:=127.0.0.1}"
: "${ROUTER_PORT:=8080}"             # mlx_lm.server's default port
: "${ROUTER_EXTRA_PORTS:=}"          # additional ports to bind, comma-separated
: "${ROUTER_SCRIPT:=${HOME}/scripts/mlx-router.py}"
: "${ROUTER_SWITCH_TIMEOUT:=90}"
: "${ROUTER_LOG_LEVEL:=INFO}"
: "${ROUTER_STATICS:=}"              # name=url[|upstream], comma-separated. Auto-derived if empty.
: "${ROUTER_TAGS_ALIAS:=}"           # alias for the tags backend; defaults to basename(TAGS_MODEL)
: "${ROUTER_EMBED_ALIAS:=embed}"     # alias for the embed backend
: "${ROUTER_TTS_ALIAS:=}"            # alias for the tts backend; defaults to basename(TTS_MODEL)

# Chat server
# Profiles: pick a chat model+draft pair by name. The active selection is
# resolved in resolve_chat_profile() below: command flag --chat-model wins
# over CHAT_PROFILE env var wins over CHAT_PROFILE_DEFAULT (config) wins
# over the literal CHAT_MODEL fallback. Edit CHAT_*_PROFILES in your
# ~/.config/mlx.conf to register new models.
typeset -gA CHAT_MODEL_PROFILES CHAT_DRAFT_PROFILES
[[ ${#CHAT_MODEL_PROFILES} -eq 0 ]] && CHAT_MODEL_PROFILES=(
    [anubis]="${MODELS_ROOT}/anubis"
)
[[ ${#CHAT_DRAFT_PROFILES} -eq 0 ]] && CHAT_DRAFT_PROFILES=(
    [anubis]="${MODELS_ROOT}/anubis-draft"
)
: "${CHAT_PROFILE_DEFAULT:=anubis}"
: "${CHAT_PROFILE:=}"          # explicit profile override (env var or --chat-model)

: "${CHAT_ENGINE:=lm}"        # lm = mlx_lm.server (text), vlm = mlx_vlm.server (multimodal)
: "${CHAT_MODEL:=${MODELS_ROOT}/anubis}"
: "${CHAT_PORT:=1234}"
: "${CHAT_DRAFT_MODEL:=${CHAT_DRAFT:-${MODELS_ROOT}/anubis-draft}}"
: "${CHAT_NUM_DRAFT_TOKENS:=5}"
: "${CHAT_PROMPT_CACHE_SIZE:=32}"
: "${CHAT_PROMPT_CACHE_BYTES:=25000000000}"
: "${CHAT_ADAPTER_PATH:=}"
: "${CHAT_LOG_LEVEL:=}"
: "${CHAT_CHAT_TEMPLATE:=}"
: "${CHAT_USE_DEFAULT_CHAT_TEMPLATE:=0}"
: "${CHAT_CHAT_TEMPLATE_ARGS:=}"
: "${CHAT_TRUST_REMOTE_CODE:=0}"
: "${CHAT_DEFAULT_TEMP:=}"
: "${CHAT_DEFAULT_TOP_P:=}"
: "${CHAT_DEFAULT_TOP_K:=}"
: "${CHAT_DEFAULT_MIN_P:=}"
: "${CHAT_DEFAULT_MAX_TOKENS:=}"
: "${CHAT_PREFILL_STEP_SIZE:=}"
: "${CHAT_DECODE_CONCURRENCY:=}"
: "${CHAT_PROMPT_CONCURRENCY:=}"

# Embed server
: "${EMBED_MODEL:=mlx-community/nomicai-modernbert-embed-base-8bit}"
: "${EMBED_PORT:=1236}"
: "${EMBED_SCRIPT:=${HOME}/scripts/mlx-embed-server.py}"

# TTS server (mlx_audio.server). Multi-model server; preloaded with TTS_MODEL
# plus any comma-separated paths in TTS_EXTRA_MODELS. All listed models stay
# resident so clients can switch by setting `model` in /v1/audio/speech.
: "${TTS_MODEL:=${MODELS_ROOT}/omnivoice}"
: "${TTS_EXTRA_MODELS:=}"
: "${TTS_PORT:=1237}"
: "${TTS_BIN:=${MLX_VENV}/bin/mlx_audio.server}"

# Kokoro server. Separate mlx_audio.server instance pinned to the
# kokoro-fastapi default port (8880), so clients that hardcode that port
# (Open WebUI TTS, etc.) find Kokoro without extra config. Shares the same
# binary as the TTS server; runs as its own process with its own pidfile.
: "${KOKORO_MODEL:=${MODELS_ROOT}/kokoro}"
: "${KOKORO_PORT:=8880}"
: "${KOKORO_BIN:=${MLX_VENV}/bin/mlx_audio.server}"

# Tag-gen server
: "${TAGS_ENGINE:=vlm}"     # qwen-tags is multimodal; needs mlx_vlm.server
: "${TAGS_MODEL:=${MODELS_ROOT}/qwen-tags}"
: "${TAGS_PORT:=1235}"
: "${TAGS_DRAFT_MODEL:=}"
: "${TAGS_NUM_DRAFT_TOKENS:=}"
: "${TAGS_PROMPT_CACHE_SIZE:=16}"
: "${TAGS_PROMPT_CACHE_BYTES:=5000000000}"
: "${TAGS_ADAPTER_PATH:=}"
: "${TAGS_LOG_LEVEL:=}"
: "${TAGS_CHAT_TEMPLATE:=}"
: "${TAGS_USE_DEFAULT_CHAT_TEMPLATE:=0}"
: "${TAGS_CHAT_TEMPLATE_ARGS:=}"
: "${TAGS_TRUST_REMOTE_CODE:=0}"
: "${TAGS_DEFAULT_TEMP:=}"
: "${TAGS_DEFAULT_TOP_P:=}"
: "${TAGS_DEFAULT_TOP_K:=}"
: "${TAGS_DEFAULT_MIN_P:=}"
: "${TAGS_DEFAULT_MAX_TOKENS:=}"
: "${TAGS_PREFILL_STEP_SIZE:=}"
: "${TAGS_DECODE_CONCURRENCY:=}"
: "${TAGS_PROMPT_CONCURRENCY:=}"

HOST="${MLX_HOST}"
LOG_DIR="${MLX_LOG_DIR}"
MLX_PY="${MLX_VENV}/bin/python"
MLX_LM_BIN="${MLX_VENV}/bin/mlx_lm.server"
MLX_VLM_BIN="${MLX_VENV}/bin/mlx_vlm.server"
MLX_BIN="${MLX_LM_BIN}"  # legacy alias for help/error messages
mkdir -p "${LOG_DIR}"

CHAT_NAME="chat"
TAGS_NAME="qwen-tags"
EMBED_NAME="embed"
TTS_NAME="tts"
KOKORO_NAME="kokoro"

# Per-server flag tables (mlx_lm.server).
# Optional value flags: only passed if the var is non-empty.
typeset -ga OPTIONAL_FLAGS=(
    "DRAFT_MODEL=--draft-model"
    "NUM_DRAFT_TOKENS=--num-draft-tokens"
    "PROMPT_CACHE_SIZE=--prompt-cache-size"
    "PROMPT_CACHE_BYTES=--prompt-cache-bytes"
    "ADAPTER_PATH=--adapter-path"
    "LOG_LEVEL=--log-level"
    "CHAT_TEMPLATE=--chat-template"
    "CHAT_TEMPLATE_ARGS=--chat-template-args"
    "DEFAULT_TEMP=--temp"
    "DEFAULT_TOP_P=--top-p"
    "DEFAULT_TOP_K=--top-k"
    "DEFAULT_MIN_P=--min-p"
    "DEFAULT_MAX_TOKENS=--max-tokens"
    "PREFILL_STEP_SIZE=--prefill-step-size"
    "DECODE_CONCURRENCY=--decode-concurrency"
    "PROMPT_CONCURRENCY=--prompt-concurrency"
)
# Boolean flags: passed (no value) if =1.
typeset -ga BOOL_FLAGS=(
    "TRUST_REMOTE_CODE=--trust-remote-code"
    "USE_DEFAULT_CHAT_TEMPLATE=--use-default-chat-template"
)

# mlx_vlm.server has a different (smaller) flag surface. No spec-dec, no
# prompt-cache size/bytes, no log level, no chat template overrides, no
# sampling defaults, no allowed-origins. KV cache is quantized via
# --kv-bits / --max-kv-size instead. Per-request sampling/template args
# come through chat_template_kwargs in the OpenAI-compatible body.
typeset -ga VLM_OPTIONAL_FLAGS=(
    "ADAPTER_PATH=--adapter-path"
    "PREFILL_STEP_SIZE=--prefill-step-size"
    "KV_BITS=--kv-bits"
    "KV_QUANT_SCHEME=--kv-quant-scheme"
    "KV_GROUP_SIZE=--kv-group-size"
    "MAX_KV_SIZE=--max-kv-size"
    "QUANTIZED_KV_START=--quantized-kv-start"
)
typeset -ga VLM_BOOL_FLAGS=(
    "TRUST_REMOTE_CODE=--trust-remote-code"
    "RELOAD=--reload"
)

